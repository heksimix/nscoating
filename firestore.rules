rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Позволяваме на всеки вписан потребител да чете и записва във всички колекции.
    // Това решава проблемите с "permission-denied" по време на прототипиране.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}